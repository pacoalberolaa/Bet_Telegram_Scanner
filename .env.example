# MongoDB Atlas
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=betscanner

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxx

# Concurrencia (workers que procesan meses en paralelo)
BETSCANNER_WORKERS=3

# Dedup tuning (opcional)
BETSCANNER_DEDUP_WINDOW_HOURS=72
BETSCANNER_PHASH_HAMMING_MAX=8

# Tennis Explorer (opcional)
BETSCANNER_TE_RATE_SECONDS=2.5
BETSCANNER_TE_FUZZY_THRESHOLD=80
BETSCANNER_TE_DAY_WINDOW=2

# Salida (opcional)
BETSCANNER_REPORTS_DIR=reports
