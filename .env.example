# MongoDB Atlas
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=bettelegramscanner

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxx

# Concurrencia (workers que procesan meses en paralelo)
BETTELEGRAMSCANNER_WORKERS=3

# Dedup tuning (opcional)
BETTELEGRAMSCANNER_DEDUP_WINDOW_HOURS=72
BETTELEGRAMSCANNER_PHASH_HAMMING_MAX=8

# Tennis Explorer (opcional)
BETTELEGRAMSCANNER_TE_RATE_SECONDS=2.5
BETTELEGRAMSCANNER_TE_FUZZY_THRESHOLD=80
BETTELEGRAMSCANNER_TE_DAY_WINDOW=2

# Salida (opcional)
BETTELEGRAMSCANNER_REPORTS_DIR=reports
